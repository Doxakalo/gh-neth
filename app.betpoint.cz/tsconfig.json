{
	"compilerOptions": {
		"rootDir": "./src",
		"target": "ES6",
		"module": "esnext",
		"moduleResolution": "node",
		"jsx": "react",
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"noImplicitAny": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"sourceMap": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"src/js/backend",
	]
}
